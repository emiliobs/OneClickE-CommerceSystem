@using OneClick.Shared.Entities

<style>
    /* Scoped styles for the card */
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        border-radius: 16px;
        overflow: hidden;
        background-color: white;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

    .product-media-container {
        text-align: center;
        padding: 20px;
        background: linear-gradient(to bottom, #f8f9fa, white);
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-media {
        max-height: 100%;
        max-width: 100%;
        transition: transform 0.3s ease;
    }

    .product-card:hover .product-media {
        transform: scale(1.05);
    }

    .price-tag {
        font-weight: bold;
        font-size: 1.5rem;
        background: linear-gradient(135deg, #d84315 0%, #b71c1c 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>

<div class="card product-card shadow-sm h-100">

    <div class="product-media-container">
        <img src="@Product.ImageURL" class="product-media" alt="@Product.Name" />
    </div>

    <div class="card-body d-flex flex-column">
        <h5 class="card-title fw-bold">@Product.Name</h5>
        <p class="card-text text-muted small flex-grow-1">@Product.Description</p>

        <hr class="my-2" />

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <small class="text-muted d-block">Price</small>
                <span class="price-tag">$@Product.Price.ToString("N2")</span>
            </div>

            @if (Product.Qty > 10)
            {
                <span class="badge bg-success">In Stock</span>
            }
            else if (Product.Qty > 5)
            {
                <span class="badge bg-warning text-dark">Low Stock</span>
            }
            else if (Product.Qty > 0)
            {
                <span class="badge bg-danger">Last Items!</span>
            }
            else
            {
                <span class="badge bg-secondary">Out of Stock</span>
            }
        </div>

        <button class="btn w-100 fw-bold @(Product.Qty > 0 ? "btn-primary" : "btn-secondary")"
                disabled="@(Product.Qty == 0)"
                @onclick="HandleClick"
                style="border-radius: 12px;">
            @(Product.Qty > 0 ? "Add to Cart" : "Out of Stock")
        </button>
    </div>
</div>

