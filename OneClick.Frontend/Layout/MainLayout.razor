@using Microsoft.AspNetCore.Components.Authorization
@using OneClick.Frontend.AuthProviders
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider _AuthenticationStateProvider
@inject NavigationManager _NavigationManager
@inject AlertService _SweetAlertService

<div class="page">

    <div class="top-row px-4" style="justify-content: space-between; display: flex; align-items: center;">

        <div class="d-flex align-items-center gap-0">
            <button class="btn text-white p-0" @onclick="ToggleSidebar">
                <i class="bi bi-list fs-3"></i>
            </button>

            <div class="d-flex align-items-center">
                <a class="d-flex text-decoration-underline" href="/">
                    <i class="bi bi-cursor text-white fs-4 m-0"></i>
                    <span class="text-white fw-bold fs-4" style="letter-spacing: 0.5px; font-family:cursive;">OneClick!</span>
                </a>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link text-white p-0" @onclick="ToggleDarkMode" title="Toggle Dark Mode">
                @if (isDarkMode)
                {
                    <i class="bi bi-sun-fill fs-4"></i>
                }
                else
                {
                    <i class="bi bi-moon-stars-fill fs-4"></i>
                }
            </button>

            <div style="border-left: 1px solid rgba(255,255,255,0.3); height: 20px;"></div>

            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center text-white gap-4">
                        <a href="/profile" class="nav-link text-white d-flex align-items-center border-0 bg-transparent text-decoration-none action-hover" title="Go to My Profile">
                            <span class="fw-bold me-2">Hi, @context.User.Identity!.Name</span>
                            
                            @* NEW: Look for the ImageUrl claim. If it exists, show the image. Otherwise, show the icon. *@
                            @{
                                var imageUrl = context.User.FindFirst("ImageUrl")?.Value;
                            }
                            @if (!string.IsNullOrEmpty(imageUrl))
                            {
                                <img src="@imageUrl" alt="Profile" class="rounded-circle" style="width: 42px; height: 42px; object-fit: cover; border: 2px solid white;" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle fs-3"></i>
                            }
                        </a>

                        <button @onclick="LogoutAsync" class="nav-link text-white d-flex align-items-center border-0 bg-transparent action-hover" style="cursor: pointer;" title="Logout">
                            <span class="me-2 fw-bold">Logout</span>
                            <i class="bi bi-box-arrow-right fs-4"></i>
                        </button>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex align-items-center text-white gap-3">
                        @* NEW: Register Button added exactly matching the style *@
                        <a href="/register" class="text-white text-decoration-none d-flex align-items-center border-0">
                            <span class="me-2 fw-bold">Register</span>
                            <i class="bi bi-person-plus fs-4"></i>
                        </a>

                        <div style="border-left: 1px solid rgba(255,255,255,0.3); height: 15px;"></div>

                        <a href="/login" class="text-white text-decoration-none d-flex align-items-center border-0">
                            <span class="me-2 fw-bold">Login</span>
                            <i class="bi bi-box-arrow-in-right fs-4"></i>
                        </a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
           
        </div>
    </div>

    <div class="body-wrapper">

        <div class="sidebar @(_sidebarOpen ? "" : "collapsed")">
            <NavMenu />
        </div>

        <main>
            <article class="content px-4">
                @Body
            </article>

            <footer class="footer text-center m-0 text-muted">
                <div class="container">
                    <span>
                        &copy; 2026 London - <i class="bi bi-cursor fs-6 m-0"></i>OneClick E-Commerce System -
                        <i class="bi bi-code-slash"></i> By Emilio Barrera Built with
                        <i class="bi bi-heart-fill" style="color: #e74c3c;"></i>
                    </span>
                </div>
            </footer>
        </main>
    </div>
</div>

@code {
    // IMPORTANTE: En móvil, es mejor empezar con el menú cerrado para ver el contenido
    private bool _sidebarOpen = true;
    private bool isDarkMode = false;
    private bool firstRender = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedTheme = await JSRuntime.InvokeAsync<string>("DarkMode.getTheme");
                if (savedTheme == "dark")
                {
                    isDarkMode = true;
                    await JSRuntime.InvokeVoidAsync("DarkMode.toggle", true);
                    StateHasChanged();
                }
            }
            catch { }
            this.firstRender = false;
        }
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        await JSRuntime.InvokeVoidAsync("DarkMode.toggle", isDarkMode);
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }

    private async Task LogoutAsync()
    {
        try
        {
            // Cast the provider to our custom to access the Logout method
            var customAuthStateProvider = (CustomAuthenticationStateProvider)_AuthenticationStateProvider;

            // Delete the token and notify the system
            await customAuthStateProvider.MarkUserAsLoggedOut();

            // Redirect the user back to the home page or login page
            _NavigationManager.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            await _SweetAlertService.ShowErrorAlert($"MainLayout Error during logout process", $"{ex.Message}");
        }
    }
}