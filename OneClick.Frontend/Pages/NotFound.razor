@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager
@inject SweetAlertService SweetAlertService

<PageTitle>404 - Not Found</PageTitle>

<div class="error-container d-flex flex-column align-items-center justify-content-center text-center">
    <div class="mb-4">
        <i class="bi bi-cone-striped text-warning" style="font-size: 5rem;"></i>
    </div>
    <h1 class="display-1 fw-bold text-danger mb-0" style="text-shadow: 0 0 10px rgba(220, 53, 69, 0.5);">
        404
    </h1>
    <h3 class="text-muted mb-3">Oops! Page not found.</h3>
    <div class="d-flex align-items-center gap-3 bg-dark bg-opacity-50 px-4 py-2 rounded-pill border border-secondary">
        <div class="spinner-border spinner-border-sm text-danger" role="status"></div>
        <span class="text-light small text-uppercase fw-bold">Redirecting Home...</span>
    </div>
</div>

<style>
    .error-container {
        min-height: 70vh;
        animation: fadeIn 0.8s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500); // Small delay for UX

            // === HERE IS THE MAGIC FOR DARK MODE ===
            var result = await SweetAlertService.FireAsync(new SweetAlertOptions
            {
                Title = "Are you lost?",
                Text = "We couldn't find that page. Let's get you back to the store.",
                Icon = SweetAlertIcon.Error,

                // 1. Dark Background (Matches your Dashboard)
                Background = "#1a1a2e",

                // 2. White Text
                Color = "#ffffff",

                // 3. Button Colors (Red for action, Grey for cancel if needed)
                ConfirmButtonColor = "#d32f2f",
                ConfirmButtonText = "GO TO HOME",

                // Block user from closing it without clicking
                AllowOutsideClick = false,
                AllowEscapeKey = false,

                // Optional: Remove default white border around popup
                CustomClass = new SweetAlertCustomClass
                {
                    Popup = "border-1 border-secondary shadow-lg"
                }
            });

            if (result.IsConfirmed)
            {
                NavigationManager.NavigateTo("/");
            }
        }
    }
}