@page "/categories"
@using OneClick.Frontend.Services
@using OneClick.Shared.Entities

<style>
    .modal-color {
        background-color: rgba(0,0,0,0.6);
        backdrop-filter: blur(3px);
    }
</style>


<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">
                <i class="bi bi-tags me-2"></i>Category Management
            </h2>
            <p class="text-muted">Manage your product categories</p>
        </div>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-lg me-1"></i>NEW CATEGORY
        </button>             
    </div>    

    <!--Filter-->
    <div class="card bg-dark text-white mb-4 border-0 shadow-sm">
        <div class="card-body p-2">
            <div class="input-group">
              
                <span class="input-group-text bg-transparent border-0 text-danger">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text"
                       class="form-control bg-transparent border-0 text-white shadow-none"
                       placeholder="Search categories by names..."
                       @bind="searchText"
                       @oninput="FilterCategories" />

            </div>
        </div>
    </div>


 <hr />
    @if (isLoading)
    {
        <!-- Loading State -->
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading categories...</p>
        </div>
    }
    else if (!filteredCategories.Any() && string.IsNullOrWhiteSpace(searchText))
    {
        <!-- Empty State -->
    <div class="alert alert-info">
        <div class="d-flex">
            <div class="me-3">
                <i class="bi bi-info-circle" style="font-size: 1.5rem;"></i>
            </div>
            <div>
                <h5 class="alert-heading">No categories yet</h5>
                <p>Start by creating your first category to organize your products.</p>
                <button class="btn btn-info btn-sm" @onclick="ShowAddForm">
                    Create First Category
                </button>
            </div>
        </div>
    </div>
    }
   else
    {        
        <!-- Categories List -->
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-responsive table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">CATEGORY</th>
                                <th class="text-center">PRODUCTS</th>
                                <th class="text-center" style="width: 150px;">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filteredCategories.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        NO categories found matching "<strong>@searchText</strong>"
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var category in PaginatedCategories)
                               {
                                    <tr>
                                        <td class="align-middle ps-4">
                                            <span class="fw-bold">@category.Name</span>
                                            <div class="small text-muted" style="color:#FF4081 !important;">ID: @category.Id</div>
                                        </td>
                                        <td class="align-middle text-center">
                                            @if (category.Products != null && category.Products.Count > 0)
                                            {
                                                <span class="badge bg-primary rounded-pill">
                                                    @category.Products.Count 
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary rounded-pill">0</span>
                                            }
                                        </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-link text-warning p-0 me-3"
                                                title="Edit"
                                                @onclick="() => EditCategory(category)">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-link text-danger p-0"
                                                title="Delete"
                                                @onclick="() => DeleteCategory(category)">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                  </tr>
                                }             
                            }
                        </tbody>
                    </table>
                </div> 
                <div class="p-1 border-top">
                    <Pagination CurrentPage="currentPage"
                                TotalPages="TotalPages"
                                SelectedPage="ChangePage" />
                </div>
            </div>
        </div>
     

<!-- Add/Edit Modal -->

@if(showFormModal)
{
    <div class="modal show d-block modal-color" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary shadow-lg">

                        <div class="modal-header border-secondary">
                            <h5 class="modal-title fw-bold">
                                <i class="bi @(currentCategory.Id == 0 ? "bi-plus-circle" : "bi-pencil-square") me-2"></i>
                                @(currentCategory.Id == 0 ? "New Category" : "Edit Category")
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseFormModel"></button>
                        </div>

                 <EditForm Model="currentCategory" OnSubmit="SaveCategory">
                     <DataAnnotationsValidator></DataAnnotationsValidator>

                     <div class="modal-body">
                         <label class="form-label text-uppercase small text-muted border-0">Name</label>
                                <InputText class="form-control bg-secondary text-white  border-secondary" style=""
                                           placeholder="Ex: Technology"
                                           @bind-Value="currentCategory.Name">
                                </InputText>
                         <ValidationMessage For="@(() => currentCategory.Name)"></ValidationMessage>
                     </div>

                 <div class="modal-footer border-secondary">
                        <button type="button" class="btn btn-secondary" @onclick="CloseFormModel" disabled="@isSaving">
                            Cancel
                        </button>
                                <button type="submit" class="btn btn-primary px-4" disabled="@(isSaving || isUploading)">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    @(isUploading ? "Uploading..." : (isEditing ? "Update" : "Save"))
                                </button>                     
                    </div>

               </EditForm>                      

            </div>
        </div>
    </div>
   }

}
</div>
