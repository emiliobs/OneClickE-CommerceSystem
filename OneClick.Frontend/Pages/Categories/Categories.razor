@page "/categories"
@using OneClick.Frontend.Services
@using OneClick.Shared.Entities
@inject ICategoryService _categoryService

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary">
                <i class="bi bi-tags me-2"></i>Categories
            </h2>
            <p class="text-muted">Manage your product categories</p>
        </div>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-circle me-1"></i>New Category
        </button>
       
    </div>    
 <hr />
    @if (isLoading)
    {
        <!-- Loading State -->
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading categories...</p>
        </div>
    }
    else if (!categories.Any())
    {
        <!-- Empty State -->
    <div class="alert alert-info">
        <div class="d-flex">
            <div class="me-3">
                <i class="bi bi-info-circle" style="font-size: 1.5rem;"></i>
            </div>
            <div>
                <h5 class="alert-heading">No categories yet</h5>
                <p>Start by creating your first category to organize your products.</p>
                <button class="btn btn-info btn-sm" @onclick="ShowAddForm">
                    Create First Category
                </button>
            </div>
        </div>
    </div>
    }
   else
    {
        
        <!-- Categories List -->
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Category Name</th>
                                <th class="text-center">Products</th>
                                <th class="text-center" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in categories)
                            {
                                <tr>
                                    <td class="align-middle ps-4">
                                        <span class="fw-bold">@category.Name</span>
                                        <div class="small text-muted">ID: @category.Id</div>
                                    </td>
                                    <td class="align-middle text-center">
                                        @if (category.Products != null && category.Products.Count > 0)
                                        {
                                            <span class="badge bg-primary rounded-pill">
                                                @category.Products.Count 
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">0</span>
                                        }
                                    </td>
                                    <td class="align-middle text-center">
                                        <button class="btn btn-warning btn-sm me-2"
                                                title="Edit"
                                                @onclick="() => EditCategory(category)">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-danger btn-sm"
                                                title="Delete"
                                                @onclick="() => DeleteCategory(category)">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>




