@page "/categories"
@using OneClick.Frontend.Services
@using OneClick.Shared.Entities
@inject ICategoryService _categoryService

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary">
                <i class="bi bi-tags me-2"></i>Categories
            </h2>
            <p class="text-muted">Manage your product categories</p>
        </div>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-circle me-1"></i>New Category
        </button>
    </div>    
    @if (isLoading)
    {
        <!-- Loading State -->
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading categories...</p>
        </div>
    }
    else if (!categories.Any())
    {
        <!-- Empty State -->
    <div class="alert alert-info">
        <div class="d-flex">
            <div class="me-3">
                <i class="bi bi-info-circle" style="font-size: 1.5rem;"></i>
            </div>
            <div>
                <h5 class="alert-heading">No categories yet</h5>
                <p>Start by creating your first category to organize your products.</p>
                <button class="btn btn-info btn-sm" @onclick="ShowAddForm">
                    Create First Category
                </button>
            </div>
        </div>
    </div>
    }
   else
    {
        <!-- Categories List -->
    <div class="row">
        @foreach (var category in categories)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@category.Name</h5>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light"
                                        type="button"
                                        data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <button class="dropdown-item" @onclick="() => EditCategory(category)">
                                            <i class="bi bi-pencil me-2"></i>Edit
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item text-danger" @onclick="() => DeleteCategory(category)">
                                            <i class="bi bi-trash me-2"></i>Delete
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <p class="card-text small text-muted">
                            ID: @category.Id
                            @if (category.Products?.Count > 0)
                            {
                                <span class="ms-2">
                                    • @category.Products.Count products
                                </span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
    }
</div>




