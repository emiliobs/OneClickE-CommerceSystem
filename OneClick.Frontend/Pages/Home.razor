@page "/"
@using OneClick.Shared.Entities
@using OneClick.Frontend.Components

<PageTitle>Home Catalog</PageTitle>

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="fw-bold">Testing Reusable Components</h2>
            <p class="text-muted">This list is rendered using the <code>&lt;ProductCard /&gt;</code> component</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>System:</strong> @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    <div class="row g-4">
        @if (products.Count > 0)
        {
            @foreach (var product in products)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">

                    <ProductCard Product="@product" OnAddToCart="@HandleAddToCart" />

                </div>
            }
        }
        else
        {
            <div class="text-center">Loading mock data...</div>
        }
    </div>
</div>

