@* Pages/Home.razor *@
@page "/"

<PageTitle>OneClick | Home</PageTitle>

@* --- SOLUCIÓN DE EMERGENCIA: ESTILOS DIRECTOS --- *@
<style>
    /* 1. Fondo y texto general */
    .home-container {
        padding: 20px;
        background-color: #15141B;
        min-height: 100vh;
        color: white;
    }

    .page-title {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
    }

    .subtitle {
        color: #808191;
        margin-bottom: 2rem;
    }

    /* 2. LA GRILLA MÁGICA (GRID) */
    .products-grid {
        display: grid;
        /* Esto hace que las tarjetas se acomoden automáticamente */
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        width: 100%; /* Asegura que use el ancho disponible */
    }
</style>

<div class="home-container">

    <h1 class="page-title">Welcome, Emilio! 👋</h1>
    <p class="subtitle">Discover our latest tech deals</p>

    @* IMPORTANTE: Aquí usamos la clase 'products-grid' que coincide con el estilo de arriba *@
    <div class="products-grid">

        @* Product 1 *@
        <ProductCard Title="USB-C Hub 6-in-1"
                     Category="Accessories"
                     Price="@(24.90m)"
                     StockUnits="15"
                     ImageUrl="https://placehold.co/300x300/1F1D2B/white?text=USB+Hub"
                     IsOnSale="true"
                     OnAddToCartClicked="HandleAddToCart" />

        @* Product 2 *@
        <ProductCard Title="Bluetooth Speaker"
                     Category="Audio"
                     Price="@(34.99m)"
                     StockUnits="25"
                     ImageUrl="https://placehold.co/300x300/1F1D2B/white?text=Speaker"
                     IsNew="true"
                     OnAddToCartClicked="HandleAddToCart" />

        @* Product 3 *@
        <ProductCard Title="Denim Jacket"
                     Category="Fashion"
                     Price="@(49.90m)"
                     StockUnits="9"
                     ImageUrl="https://placehold.co/300x300/1F1D2B/white?text=Jacket"
                     OnAddToCartClicked="HandleAddToCart" />

        @* Product 4 *@
        <ProductCard Title="Cotton T-Shirt"
                     Category="Fashion"
                     Price="@(14.99m)"
                     StockUnits="60"
                     ImageUrl="https://placehold.co/300x300/1F1D2B/white?text=T-Shirt"
                     IsOnSale="true"
                     OnAddToCartClicked="HandleAddToCart" />

    </div>

    @* Feedback Message *@
    @if (!string.IsNullOrEmpty(LastAddedProduct))
    {
        <div class="alert alert-success mt-4">
            <i class="bi bi-check-circle-fill"></i> You added <strong>@LastAddedProduct</strong> to the cart!
        </div>
    }
</div>

