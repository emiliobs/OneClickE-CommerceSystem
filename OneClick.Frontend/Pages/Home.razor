@page "/"
@using OneClick.Frontend.Pages.Products
@using OneClick.Shared.Entities
@using OneClick.Frontend.Components

<style>
    /* Custom class for the Hero Banner gradient */
    .hero-banner {
        background: linear-gradient(135deg, #d84315 0%, #b71c1c 100%);
        color: white;
    }
       

    .floating-container {
        position: fixed;
        bottom: 32px;
        right: 40px;
        z-index: 1000; /* Asegura que flote sobre todo lo demás */


    }
    /* Animación suave al pasar el mouse (opcional) */
    .btn-danger {
        transition: transform 0.2s ease-in-out;
    }

        .btn-danger:hover {
            transform: scale(1.1); /* Efecto de "crecer" */
        }
    
</style>

<PageTitle>Catalog - OneClick</PageTitle>

<div class="container-fluid p-3">

    <!-- Contenedor fijo en la esquina -->
    <div class="floating-container">
        <button class="btn btn-danger rounded-circle shadow-lg d-flex align-items-center justify-content-center"
                style="width: 60px; height: 60px;" @onclick="ShowCart">

            <!-- Icono (usando Bootstrap Icons) -->
            <i class="bi bi-cart3 fs-4"></i>

            <!-- Burbuja del contador -->
            @if (cartCount > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white shadow-sm"
                      style="font-size: 0.8rem; padding: 0.5em 0.7em;">
                    @(cartCount > 99 ? "99+" : cartCount)
                    <span class="visually-hidden">items</span>
                </span>
            }
        </button>
    </div>

    @if (products is null && isLoading)
    {
        <div class="d-flex">
            <div class="d-flex flex-column align-items-center justify-content-center py-5">
                <div class="spinner-border text-danger" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h5 class="mt-3 text-secondary">Loading products.....</h5>
            </div>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="p-4 text-white rounded-3 shadow-sm hero-banner text-center">
                    <h1 class="display-5 fw-bold">Welcome, just OneClick away 🚀</h1>
                    <p class="lead opacity-75">
                        Discover premium technology at unbeatable prices. Fast, secure, and easy.
                    </p>
                </div>
            </div>
        </div>

        <ProductFilters Categories="@categories"
                        ResultCount="@GetFilteredAndPAginateProducts().Count"
						TotalProductCount="@products!.Count"
                        @bind-SearchText="SearchText"
                        @bind-SelectedCategory="SelectedCategory"
                        @bind-SelectedStatus="SelectedStatus">
        </ProductFilters>

        @if (GetFilteredAndPAginateProducts().Count == 0)
        {
             //Task.Delay(1000); // Small delay for UX

            <div class="text-center py-5">
                <div class="spinner-border text-danger" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading.....</span>
                </div>

                <h3 class="text-muted mt-3">Loading products...</h3>
                <p class="text-secondary">Please wait. Try adjusting your search or filters..</p>
            </div>
        }
        else
        {
            <div class="row g-4">

                @foreach (var product in GetFilteredAndPAginateProducts())
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <ProductCard Product="@product" OnAddToCart="@HandleAddToCart" OnViewDetails="ShowProductDetails" />
                    </div>
                }

            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <Pagination CurrentPage="currentPage" TotalPages="totalPages" SelectedPage="PageChanged"></Pagination>
                </div>
            </div>

            <ProductDetailModal 
                Product="_selectedProduct" 
                OnClose="@(() => _selectedProduct = null)">
            </ProductDetailModal>
        }        
    }   

   

    <ShoppingCart @bind-IsOpen="showCart"></ShoppingCart>

</div>
