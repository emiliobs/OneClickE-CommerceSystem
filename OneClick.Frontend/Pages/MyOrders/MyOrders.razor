@page "/my-orders"
@using Microsoft.AspNetCore.Authorization
@using OneClick.Shared.Entities
@attribute [Authorize]

<PageTitle>My Order History - OneClick</PageTitle>

<style>
    @@media print {
        body * { visibility: hidden; }
        #print-section, #print-section * { visibility: visible; }
        #print-section { position: absolute; left: 0; top: 0; width: 100%; }
        .no-print { display: none !important; }
    }
</style>

<div class="container py-4" style="color: white;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger m-0">
            <i class="bi bi-box2-heart-fill me-2"></i>My Order History
        </h2>
    </div>

    <div class="card bg-dark text-white mb-4 border-0 shadow-sm">
        <div class="card-body p-2">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0 text-danger">
                    <i class="bi bi-search"></i>
                </span>

                <input type="text"
                       class="form-control bg-transparent border-0 text-white shadow-none"
                       placeholder="Search orders by ID or status..."
                       value="@searchText"
                       @oninput="FilterOrders" />
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger"></div>
            <p class="mt-2 text-secondary">Loading your purchases...</p>
        </div>
    }
    else if (!filteredOrders.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-receipt text-secondary" style="font-size:4rem;"></i>
            <h4 class="mt-3">No orders found</h4>
            <p class="text-secondary">We couldn't find any orders matching your criteria.</p>
            <a href="/" class="btn btn-outline-danger mt-3 px-4">Go Shopping</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0" style="background-color:#232342;">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-dark table-hover table-striped mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">ORDER NO.</th>
                                <th>DATE</th>
                                <th>TOTAL</th>
                                <th class="text-center">STATUS</th>
                                <th class="text-end pe-4">ACTIONS</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in PaginatedOrders)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-info fw-bold">
                                        £@order.TotalAmount.ToString("0.00")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetStatusBadgeClass(order.OrderStatus) rounded-pill px-3 py-2">
                                            @order.OrderStatus
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-outline-primary btn-sm rounded-pill px-4"
                                                @onclick="() => ShowDetails(order)">
                                            DETAILS
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="p-2 border-top border-secondary">
                    <Pagination CurrentPage="currentPage"
                                TotalPages="TotalPages"
                                SelectedPage="ChangePage" />
                </div>

            </div>
        </div>
    }

    @if (selectedOrder != null)
    {
        <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.7);">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg"
                     style="background-color:#1a1a2e;"
                     id="print-section">

                    <div class="modal-header bg-danger text-white border-0">
                        <h5 class="modal-title fw-bold">
                            Customer Information
                        </h5>

                        <button class="btn-close btn-close-white no-print"
                                @onclick="CloseDetails"></button>
                    </div>

                    <div class="modal-body text-white p-4">

                        <div class="row mb-4 bg-dark p-3 rounded-3 border border-secondary">
                            <div class="col-md-6">
                                <p><strong>Name:</strong> @selectedOrder.User?.FirstName @selectedOrder.User?.LastName</p>
                                <p><strong>Email:</strong> @selectedOrder.User?.Email</p>
                            </div>

                            <div class="col-md-6">
                                <p><strong>Order:</strong> #@selectedOrder.Id</p>
                                <p><strong>Date:</strong> @selectedOrder.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                        </div>

                        <table class="table table-dark table-striped">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Sub Total</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (selectedOrder.OrderItems != null)
                                {
                                    @foreach (var item in selectedOrder.OrderItems)
                                    {
                                        <tr>
                                            <td>@(item.Product?.Name ?? "Unknown")</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">£@item.Price.ToString("0.00")</td>
                                            <td class="text-end fw-bold text-success">
                                                £@((item.Price * item.Quantity).ToString("0.00"))
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                    </div>

                    <div class="modal-footer bg-dark border-0 d-flex justify-content-between">
                        <div class="bg-danger px-4 py-2 rounded fw-bold">
                            Total: £@selectedOrder.TotalAmount.ToString("0.00")
                        </div>

                        <div class="no-print">
                            <button class="btn btn-outline-light me-2"
                                    @onclick="PrintInvoiceAsync">
                                PRINT
                            </button>

                            <button class="btn btn-secondary"
                                    @onclick="CloseDetails">
                                CLOSE
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    }

</div>