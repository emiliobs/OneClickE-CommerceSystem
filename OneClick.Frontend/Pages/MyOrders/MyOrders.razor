@page "/my-orders"

<div class="container py-5" style="color: white;">
    <h2 class="mb-4 fw-bold text-danger">
        <i class="bi bi-box-seam me-2"></i>My Order History
    </h2>

    <div class="card border-0 shadow-lg" style="background-color: #232342; color: white;">
        <div class="card-body p-4">
            
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <span class="spinner-border text-danger" role="status" aria-hidden="true" style="width: 3rem; height: 3rem;"></span>
                    <h5 class="mt-3 text-secondary">Loading your orders...</h5>
                </div>
            }
            else if (orders == null || !orders.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-receipt text-secondary" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">No orders found</h4>
                    <p class="text-secondary">Looks like you haven't made any purchases yet.</p>
                    <a href="/" class="btn btn-outline-danger mt-2">Go Shopping</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-borderless table-hover align-middle" style="color: white;">
                        <thead style="border-bottom: 2px solid #dc3545;">
                            <tr>
                                <th scope="col" class="text-secondary pb-3">Order ID</th>
                                <th scope="col" class="text-secondary pb-3">Date</th>
                                <th scope="col" class="text-secondary pb-3">Items</th>
                                <th scope="col" class="text-secondary pb-3">Total Amount</th>
                                <th scope="col" class="text-secondary pb-3">Status</th>
                                <th scope="col" class="text-secondary pb-3 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr style="border-bottom: 1px solid #333;">
                                    <td class="py-3 fw-bold">#@order.Id</td>
                                    <td class="py-3">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3">
                                        @* Calculate total items inside this specific order *@
                                        @(order.OrderItems?.Sum(i => i.Quantity) ?? 0) items
                                    </td>
                                    <td class="py-3 fw-bold text-success">£@order.TotalAmount.ToString("0.00")</td>
                                    <td class="py-3">
                                        <span class="badge bg-warning text-dark">@order.OrderStatus</span>
                                    </td>
                                    <td class="py-3 text-end">
                                        <button class="btn btn-sm btn-outline-light" @onclick="() => ShowDetails(order)">
                                            <i class="bi bi-eye"></i> Details
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@if (selectedOrder != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.7);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow-lg" style="background-color: #232342; border: 1px solid #dc3545;">
                
                <div class="modal-header border-0 bg-danger text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-cart-check me-2"></i>Order #@selectedOrder.Id Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                </div>
                
                <div class="modal-body p-4 text-white">
                    <div class="table-responsive">
                        <table class="table table-dark table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Quantity</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (selectedOrder.OrderItems != null)
                                {
                                    @foreach (var item in selectedOrder.OrderItems)
                                    {
                                        <tr>
                                            <td>
                                                @* Show product name if available, otherwise show ID *@
                                                @(item.Product?.Name ?? $"Product #{item.ProductId}")
                                            </td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">£@item.Price.ToString("0.00")</td>
                                            <td class="text-end text-success fw-bold">
                                                £@((item.Quantity * item.Price).ToString("0.00"))
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <div class="modal-footer border-0 d-flex justify-content-between">
                    <h4 class="fw-bold mb-0">Total: <span class="text-danger">£@selectedOrder.TotalAmount.ToString("0.00")</span></h4>
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetails">Close</button>
                </div>

            </div>
        </div>
    </div>
}