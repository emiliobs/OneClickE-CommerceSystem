@page "/my-orders"
@using Microsoft.AspNetCore.Authorization
@using OneClick.Shared.Entities
@attribute [Authorize]

<PageTitle>My Order History - OneClick</PageTitle>

<style>
    /* Styles to ensure the modal looks good on screen */
    .modal-content { border-radius: 15px !important; }

    @@media print {
        /* 1. Hide everything except the modal */
        body * { visibility: hidden; }
        #print-section, #print-section * { visibility: visible; }
        #print-section { 
            position: absolute; left: 0; top: 0; width: 100%; 
            background-color: white !important; color: black !important;
        }
        /* 2. Force light colors for the printer */
        .modal-body, .modal-header, .table, .bg-dark { 
            background-color: white !important; color: black !important; 
        }
        .text-white, .text-info, .text-success { color: black !important; }
        .no-print { display: none !important; }
        /* 3. Total box styling for printing */
        .bg-danger { 
            background-color: #f0f0f0 !important; 
            color: black !important; 
            border: 1px solid #ccc !important; 
        }
    }
</style>

<div class="container py-4" style="color: white;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger m-0">
            <i class="bi bi-box2-heart-fill me-2"></i>My Order History
        </h2>
    </div>

    @* Search Bar *@
    <div class="card bg-dark text-white mb-4 border-0 shadow-sm">
        <div class="card-body p-2">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0 text-danger">
                    <i class="bi bi-search"></i>
                </span>

                <input type="text"
                       class="form-control bg-transparent border-0 text-white shadow-none"
                       placeholder="Search orders by ID or status..."
                       value="@searchText"
                       @oninput="FilterOrders" />
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger"></div>
            <p class="mt-2 text-secondary">Loading your purchases...</p>
        </div>
    }
    else if (!filteredOrders.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-receipt text-secondary" style="font-size:4rem;"></i>
            <h4 class="mt-3">No orders found</h4>
            <p class="text-secondary">We couldn't find any orders matching your criteria.</p>
            <a href="/" class="btn btn-outline-danger mt-3 px-4">Go Shopping</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0" style="background-color:#232342;">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-dark table-hover table-striped mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">ORDER NO.</th>
                                <th>DATE</th>
                                <th>TOTAL</th>
                                <th class="text-center">STATUS</th>
                                <th class="text-end pe-4">ACTIONS</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in PaginatedOrders)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-info fw-bold">
                                        £@order.TotalAmount.ToString("0.00")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetStatusBadgeClass(order.OrderStatus) rounded-pill px-3 py-2">
                                            @order.OrderStatus
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-outline-primary btn-sm rounded-pill px-4"
                                                @onclick="() => ShowDetails(order)">
                                            DETAILS
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="p-2 border-top border-secondary">
                    <Pagination CurrentPage="currentPage"
                                TotalPages="TotalPages"
                                SelectedPage="ChangePage" />
                </div>

            </div>
        </div>
    }

@if (selectedOrder != null)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.85); z-index: 1050;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="background-color:#1a1a2e; border-radius: 15px;" id="print-section">
                
                @* OneClick Style Header *@
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold w-100 text-center">
                        <i class="bi bi-person-vcard me-2"></i>Customer Information
                    </h5>
                    <button class="btn-close btn-close-white no-print" @onclick="CloseDetails"></button>
                </div>

                <div class="modal-body text-white p-4">
                    @* Customer Info - 2 Column Grid *@
                    <div class="row mb-4 bg-dark bg-opacity-50 p-3 rounded-3 border border-secondary border-opacity-25">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <span class="text-info small">Name:</span> 
                                <span class="fw-bold">@selectedOrder.ShippingName</span>
                            </p>
                            <p class="mb-2">
                                <span class="text-info small">Email:</span> 
                                <span class="fw-bold">@(selectedOrder.User?.Email ?? "N/A")</span>
                            </p>
                            <p class="mb-0">
                                <span class="text-info small">Address:</span> 
                                <span class="fw-bold">@selectedOrder.ShippingAddress, @selectedOrder.City</span>
                            </p>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <p class="mb-2">
                                <span class="text-info small">Phone:</span> 
                                <span class="fw-bold">@selectedOrder.ShippingPhone</span>
                            </p>
                            <p class="mb-2">
                                <span class="text-info small">Date:</span> 
                                <span class="fw-bold">@selectedOrder.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </p>
                            <p class="mb-0">
                                <span class="text-info small">Status:</span> 
                                <span class="badge @GetStatusBadgeClass(selectedOrder.OrderStatus) rounded-pill ms-2 px-3 py-2">
                                    @selectedOrder.OrderStatus
                                </span>
                            </p>
                        </div>
                    </div>

                    <h5 class="text-danger fw-bold mb-3">
                        <i class="bi bi-cart-fill me-2"></i>Ordered Products
                    </h5>

                    @* Stylized Product Table *@
                    <div class="table-responsive">
                        <table class="table table-dark table-borderless align-middle mb-0">
                            <thead class="text-secondary small border-bottom border-secondary">
                                <tr>
                                    <th><i class="bi bi-box-seam me-2"></i>Product</th>
                                    <th class="text-center"># Quantity</th>
                                    <th class="text-end">$ Unit Price</th>
                                    <th class="text-end"><i class="bi bi-calculator me-2"></i>Sub-Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in selectedOrder.OrderItems)
                                {
                                    <tr class="border-bottom border-secondary border-opacity-10">
                                        <td class="py-3">@(item.Product?.Name ?? "Unknown Product")</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary rounded-pill">@item.Quantity</span>
                                        </td>
                                        <td class="text-end">£@item.Price.ToString("N2")</td>
                                        <td class="text-end fw-bold text-success">
                                            £@((item.Price * item.Quantity).ToString("N2"))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* Footer with Total and Buttons *@
                <div class="modal-footer border-0 p-4 d-flex justify-content-between align-items-center">
                    <div class="bg-danger bg-opacity-75 px-4 py-3 rounded shadow-sm">
                        <h4 class="m-0 fw-bold text-white">
                            <i class="bi bi-receipt me-2"></i>Total: £@selectedOrder.TotalAmount.ToString("N2")
                        </h4>
                    </div>

                    <div class="d-flex gap-2 no-print">
                        <button class="btn btn-outline-light px-4 py-2 d-flex align-items-center gap-2" @onclick="PrintInvoiceAsync">
                            <i class="bi bi-printer"></i> PRINT
                        </button>
                        <button class="btn btn-secondary px-4 py-2" @onclick="CloseDetails">
                            <i class="bi bi-check2 me-2"></i> CLOSE
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
}
</div>