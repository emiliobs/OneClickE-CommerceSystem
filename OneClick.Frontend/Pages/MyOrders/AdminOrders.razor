@page "/admin/orders"
@using Microsoft.AspNetCore.Authorization
@using OneClick.Shared.Entities
@using OneClick.Frontend.Components
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Global Order Management - OneClick</PageTitle>

<style>
    /* Screen Hover Effects */
    .admin-table-row {
        transition: background-color 0.2s ease;
    }
    .admin-table-row:hover {
        background-color: rgba(220, 53, 69, 0.05) !important;
    }

    /* High-End Print logic */
    @@media print {
        body * { visibility: hidden; }
        #print-section, #print-section * { visibility: visible; }
        #print-section { 
            position: absolute; left: 0; top: 0; width: 100%; 
            background-color: white !important; color: black !important;
            box-shadow: none !important;
        }
        .modal-header { 
            background-color: #f8f9fa !important; 
            color: black !important; 
            border-bottom: 2px solid black !important; 
        }
        .modal-body, .table { 
            background-color: white !important; 
            color: black !important; 
        }
        /* Convert badges to simple text with borders for printing */
        .badge { 
            border: 1px solid black !important; 
            color: black !important; 
            background: transparent !important; 
        }
        .text-info, .text-success, .text-white, .text-secondary { 
            color: black !important; 
        }
        .no-print { display: none !important; }
        .bg-danger { 
            background-color: #eee !important; 
            color: black !important; 
            border: 1px solid black !important; 
        }
    }
</style>

<div class="container py-4" style="color: white;">   

    

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger m-0">
            <i class="bi bi-box-seam-fill me-2"></i>Global Order Management
        </h2>
    </div>

    @* Professional Search Card *@
    <div class="card bg-dark text-white mb-4 border-0 shadow-lg" style="border-radius: 12px;">
        <div class="card-body p-2">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0 text-danger">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control bg-transparent border-0 text-white shadow-none"
                       placeholder="Search by customer name, order ID, or status..."
                       value="@searchText" @oninput="FilterOrders" />
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="mt-2 text-secondary">Synchronizing database orders...</p>
        </div>
    }
    else if (!filteredOrders.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-secondary" style="font-size: 4rem; opacity: 0.3;"></i>
            <h4 class="mt-3 text-secondary">No records found</h4>
        </div>
    }
    else
    {
        <div class="card shadow-lg border-0" style="background-color: #1e1e38; border-radius: 15px; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0 align-middle">
                        <thead>
                            <tr style="background-color: rgba(220, 53, 69, 0.1);">
                                <th class="ps-4 py-3 text-danger text-uppercase small fw-bold">ID</th>
                                <th class="py-3 text-secondary text-uppercase small fw-bold">Customer</th>
                                <th class="py-3 text-secondary text-uppercase small text-center fw-bold">Items</th>
                                <th class="py-3 text-secondary text-uppercase small fw-bold">Total</th>
                                <th class="py-3 text-secondary text-uppercase small text-center fw-bold">Status</th>
                                <th class="pe-4 py-3 text-secondary text-uppercase small text-end fw-bold">Quick Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in PaginatedOrders)
                            {
                                <tr class="admin-table-row" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <td class="ps-4 py-3 fw-bold text-info">#@order.Id</td>
                                    <td class="py-3">
                                        <div class="d-flex flex-column">
                                            <span>@(order.User?.FirstName ?? "N/A") @(order.User?.LastName ?? "")</span>
                                            <small class="text-muted" style="font-size: 0.75rem;">@order.OrderDate.ToString("MMM dd, yyyy")</small>
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        <span class="badge bg-dark border border-secondary text-secondary rounded-pill">
                                            @order.OrderItems.Sum(x => x.Quantity)
                                        </span>
                                    </td>
                                    <td class="py-3 fw-bold text-success">£@order.TotalAmount.ToString("N2")</td>
                                    <td class="py-3 text-center">
                                        <span class="@GetStatusBadgeClass(order.OrderStatus) rounded-pill px-3 py-2 shadow-sm" style="font-size: 0.8rem;">
                                            @order.OrderStatus
                                        </span>
                                    </td>
                                    <td class="pe-4 py-3 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-info rounded-circle shadow-sm" @onclick="() => ShowDetails(order.Id)" title="View Details">
                                                <i class="bi bi-eye-fill text-white"></i>
                                            </button>
                                            <select class="form-select form-select-sm bg-dark text-white border-secondary w-auto shadow-none"
                                                    style="border-radius: 8px; font-size: 0.85rem;"
                                                    @onchange="@(e => ChangeStatusAsync(order.Id, e.Value?.ToString()))">
                                                <option value="Pending" selected="@(order.OrderStatus == "Pending")">Pending</option>
                                                <option value="Shipped" selected="@(order.OrderStatus == "Shipped")">Shipped</option>
                                                <option value="Delivered" selected="@(order.OrderStatus == "Delivered")">Delivered</option>
                                                <option value="Cancelled" selected="@(order.OrderStatus == "Cancelled")">Cancelled</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="p-3 border-top border-secondary border-opacity-25 bg-dark bg-opacity-25">
                    <Pagination CurrentPage="currentPage" TotalPages="TotalPages" SelectedPage="ChangePage" />
                </div>
            </div>
        </div>
    }

    @* Enhanced Order Details Modal *@
    @if (selectedOrder != null)
    {
        <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.85); z-index: 1050;">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="background-color:#1a1a2e; border-radius: 15px; overflow: hidden;" id="print-section">
                    
                    <div class="modal-header bg-danger text-white border-0 py-3">
                        <h5 class="modal-title fw-bold w-100 text-center">
                            <i class="bi bi-file-earmark-text me-2"></i>MANAGE ORDER #@selectedOrder.Id
                        </h5>
                        <button class="btn-close btn-close-white no-print" @onclick="CloseDetails"></button>
                    </div>

                    <div class="modal-body text-white p-4">
                        @* Shipping & Customer Info Grid *@
                        <div class="row mb-4 bg-dark bg-opacity-50 p-3 rounded-3 border border-secondary border-opacity-25 shadow-inner">
                            <div class="col-md-6 border-end border-secondary border-opacity-25">
                                <h6 class="text-danger small text-uppercase fw-bold mb-3">Customer Details</h6>
                                <p class="mb-2"><span class="text-info small">Name:</span> <span class="fw-bold">@selectedOrder.ShippingName</span></p>
                                <p class="mb-2"><span class="text-info small">Email:</span> <span class="fw-bold">@(selectedOrder.User?.Email ?? "N/A")</span></p>
                                <p class="mb-0"><span class="text-info small">Phone:</span> <span class="fw-bold">@selectedOrder.ShippingPhone</span></p>
                            </div>
                            <div class="col-md-6 ps-md-4">
                                <h6 class="text-danger small text-uppercase fw-bold mb-3">Logistics Info</h6>
                                <p class="mb-2"><span class="text-info small">Address:</span> <span class="fw-bold">@selectedOrder.ShippingAddress, @selectedOrder.City</span></p>
                                <p class="mb-2"><span class="text-info small">Date:</span> <span class="fw-bold">@selectedOrder.OrderDate.ToString("MMM dd, yyyy HH:mm")</span></p>
                                <p class="mb-0">
                                    <span class="text-info small">Current Status:</span> 
                                    <span class="badge @GetStatusBadgeClass(selectedOrder.OrderStatus) ms-2">@selectedOrder.OrderStatus</span>
                                </p>
                            </div>
                        </div>

                        <h6 class="text-danger fw-bold text-uppercase mb-3" style="letter-spacing: 1px;">
                            <i class="bi bi-cart4 me-2"></i>Order Breakdown
                        </h6>

                        <div class="table-responsive">
                            <table class="table table-dark table-borderless align-middle mb-0">
                                <thead>
                                    <tr class="text-secondary small border-bottom border-secondary">
                                        <th class="py-2">PRODUCT DESCRIPTION</th>
                                        <th class="py-2 text-center">QTY</th>
                                        <th class="py-2 text-end">UNIT PRICE</th>
                                        <th class="py-2 text-end">SUBTOTAL</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in selectedOrder.OrderItems)
                                    {
                                        <tr class="border-bottom border-secondary border-opacity-10">
                                            <td class="py-3">@(item.Product?.Name ?? "N/A")</td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary rounded-pill">@item.Quantity</span>
                                            </td>
                                            <td class="text-end">£@item.Price.ToString("N2")</td>
                                            <td class="text-end fw-bold text-success">£@((item.Price * item.Quantity).ToString("N2"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="modal-footer border-0 p-4 bg-dark bg-opacity-25 d-flex justify-content-between align-items-center">
                        <div class="bg-danger bg-opacity-75 px-4 py-3 rounded shadow-lg">
                            <h4 class="m-0 fw-bold text-white">
                                <i class="bi bi-cash-stack me-2"></i>TOTAL: £@selectedOrder.TotalAmount.ToString("N2")
                            </h4>
                        </div>
                        <div class="no-print">
                            <button class="btn btn-outline-light px-4 py-2 me-2 d-inline-flex align-items-center gap-2 shadow-sm" @onclick="PrintInvoiceAsync">
                                <i class="bi bi-printer-fill"></i> PRINT INVOICE
                            </button>
                            <button class="btn btn-secondary px-4 py-2" @onclick="CloseDetails">
                                CLOSE
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>