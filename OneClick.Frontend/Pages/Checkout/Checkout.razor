@page "/checkout"
@using OneClick.Shared.Entities

<div class="container py-5" style="color: white;">
    <h2 class="mb-4 fw-bold text-danger"><i class="bi bi-credit-card-2-front me-2"></i>Checkout</h2>
    
    <EditForm Model="order" OnValidSubmit="ProcessCheckout">
        <DataAnnotationsValidator />

        <div class="row">
            <div class="col-md-8">
                <div class="card border-0 shadow-lg mb-4" style="background-color: #232342; color: white;">
                    <div class="card-header border-0 bg-transparent py-3">
                        <h5 class="mb-0 text-danger fw-bold">1. Shipping Address</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-secondary">Full Name</label>
                                <InputText @bind-Value="order.ShippingName" class="form-control bg-dark text-white border-secondary" placeholder="Emilio Barrera" />
                                <ValidationMessage For="@(() => order.ShippingName)" class="text-danger" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary">Phone</label>
                                <InputText @bind-Value="order.ShippingPhone" class="form-control bg-dark text-white border-secondary" placeholder="+44 7700 900000" />
                                <ValidationMessage For="@(() => order.ShippingPhone)" class="text-danger" />
                            </div>
                            <div class="col-12">
                                <label class="form-label text-secondary">Address Line 1</label>
                                <InputText @bind-Value="order.ShippingAddress" class="form-control bg-dark text-white border-secondary" placeholder="123 London Met Street" />
                                <ValidationMessage For="@(() => order.ShippingAddress)" class="text-danger" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary">City</label>
                                <InputText @bind-Value="order.City" class="form-control bg-dark text-white border-secondary" placeholder="London" />
                                <ValidationMessage For="@(() => order.City)" class="text-danger" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary">Postcode</label>
                                <InputText @bind-Value="order.Postcode" class="form-control bg-dark text-white border-secondary" placeholder="N7 8DB" />
                                <ValidationMessage For="@(() => order.Postcode)" class="text-danger" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-lg" style="background-color: #232342; color: white;">
                    <div class="card-header border-0 bg-transparent py-3">
                        <h5 class="mb-0 text-danger fw-bold">2. Payment Method</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex gap-3">
                            <div class="border border-danger rounded p-3 text-center" style="width: 100px; cursor: pointer; background: rgba(220, 53, 69, 0.1);">
                                <i class="bi bi-credit-card fs-3 text-danger"></i>
                                <div class="small mt-1">Card</div>
                            </div>
                            <div class="border border-secondary rounded p-3 text-center" style="width: 100px; cursor: pointer; opacity: 0.5;">
                                <i class="bi bi-paypal fs-3 text-primary"></i>
                                <div class="small mt-1">PayPal</div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <label class="form-label text-secondary">Card Number (Demo)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-secondary text-secondary"><i class="bi bi-credit-card"></i></span>
                                <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="3232 3232 3232 3232">
                            </div>
                            <small class="text-secondary mt-1">Payment processing is simulated for this project.</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-lg position-sticky" style="top: 20px; background-color: #1a1a2e; border: 1px solid #333 !important;">
                    <div class="card-header border-0 bg-transparent py-3">
                        <h5 class="mb-0 text-white">Summary</h5>
                    </div>
                    <div class="card-body">
                        @*  Show a loading spinner while fetch cart data *@
                        @if (isLoadingSummary)
                        {
                            <div class="text-center py-4">
                                <span class="spinner-border text-secondary" role="status" aria-hidden="true"></span>
                                <span class="ms-2 text-secondary">Calculating totals.....</span>
                            </div>
                        }
                        else
                        {
                           @*  Once load, show the real dynamic varables *@
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-secondary">Subtotal</span>
                                <span class="text-secondary">Subtotal (@totalItems items)</span>
                                <span class="text-white">£@cartTotal.ToString("0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-secondary">Shipping</span>
                                <span class="text-success">Free</span>
                            </div>
                            <hr class="border-secondary">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <span class="fs-5 fw-bold">Total</span>
                                <span class="fs-4 fw-bold text-danger">£@cartTotal.ToString("0.00")</span>
                            </div>
                        }
                        
                        
                        <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5 shadow" disabled="@isProcessing">
                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span> Processing...</span>
                            }
                            else
                            {
                                <span>CONFIRM PAYMENT <i class="bi bi-lock-fill ms-2"></i></span>
                            }
                        </button>
                        
                        <div class="text-center mt-3 small text-secondary">
                            <i class="bi bi-shield-check me-1"></i> Secure Transaction
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </EditForm>
</div>