@page "/about"

<div class="container py-5 text-white">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-4 text-danger">OneClick<span class="text-muted">!</span></h1>
        <p class="lead text-muted">Modernizing E-Commerce for small and medium-sized enterprises.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-lg h-100" style="background-color: #232342;">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-3 text-white"><i class="bi bi-rocket-takeoff text-danger me-2"></i>Our Mission</h3>
                    <p class="text-light opacity-75">
                        OneClick is a high-performance platform engineered to eliminate the friction of traditional e-commerce:
                        latency, insecure payment flows, and rigid legacy architectures.
                    </p>
                    <p class="text-light opacity-75 mb-5">
                        Leveraging the power of the <strong>Azure Cloud</strong> and the unprecedented speed of <strong>.NET 10</strong>,
                        we deliver a safe, blazing-fast, and infinitely scalable shopping experience.
                    </p>

                     <hr class="border-secondary my-4" />


                    <h5 class="fw-bold mt-4 mb-3 text-white">Technologies Used:</h5>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-primary">.NET 10</span>
                        <span class="badge bg-danger">ASP.NET Core MVC API</span>
                        <span class="badge bg-purple" style="background-color: #6f42c1;">Blazor WebAssembly</span>
                        <span class="badge bg-info">Azure SQL / SQL Server</span>
                        <span class="badge bg-secondary">Entity Framework Core</span>
                        <span class="badge bg-warning">Visual Studio 2026</span>
                        <span class="badge bg-success">OWASP Security</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-lg h-100" style="background-color: #1a1a2e; border: 1px solid #333 !important;">
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <div class="rounded-circle bg-danger d-inline-flex align-items-center justify-content-center text-white fw-bold shadow"
                             style="width: 100px; height: 100px; font-size: 2.5rem;">
                            EB
                        </div>
                    </div>

                    <h4 class="fw-bold text-white">Emilio Antonio Barrera Sepulveda</h4>
                    <p class="text-secondary mb-1">Full-Stack Developer</p>
                    <p class="text-secondary small">London Metropolitan University</p>

                    <hr class="border-secondary my-4" />

                    <div class="d-grid gap-2">
                        <a href="mailto:eab0132@my.londonmet.ac.uk" class="btn btn-outline-light">
                            <i class="bi bi-envelope-at-fill me-2"></i> Contact
                        </a>
                        <button class="btn btn-outline-secondary" disabled>
                            Student ID: 22047055
                        </button>
                    </div>

                    <div class="mt-4 pt-2">
