@page "/products"

<style>
    .modal-color{
        background-color: rgba(0,0,0,0.6); backdrop-filter: blur(3px);
    }
</style>

<div class="container py-3">

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <h2 class="fw-bold" style="color:#D32F2F;">
                <i class="bi bi-box-seam me-2"></i>Product Management
            </h2>
            <p class="text-muted">Manage your catalog and inventory</p>
        </div>
        <button class="btn btn-danger" @onclick="ShowAddForm">
            <i class="bi bi-plus-lg me-2"></i>NEW PRODUCT
        </button>
    </div>

    <div class="card bg-dark text-white mb-4 border-0 shadow-sm">
        <div class="card-body p-2">
            <div class="input-group">
               
                <span class="input-group-text bg-transparent border-0 text-danger">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text"
                       class="form-control bg-transparent border-0 text-white shadow-none"
                       placeholder="Search products by name, description or category..."
                       value="@searchText"
                       @oninput="FilterProducts" />
            </div>
        </div>
    </div>
    <hr />
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading products...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm" style="min-height: 400px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-responsive table-hover align-middle mb-0">
                        <thead class="text-muted text-uppercase small border-bottom border-secondary">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th class="ps-4">Product</th>
                                <th>Category</th>
                                <th>Stock (Qty)</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filteredProducts.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        No products found matching "<strong>@searchText</strong>"
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var product in PaginatedProducts)
                                {
                                    <tr>
                                        <td class="ps-4 align-middle" style="color:#FF4081 !important;">
                                            #@product.Id
                                        </td>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3 rounded bg-secondary d-flex align-items-center justify-content-center"
                                                     style="width: 48px; height: 48px; overflow: hidden;">
                                                    @if (string.IsNullOrEmpty(product.ImageURL))
                                                    {
                                                        <i class="bi bi-image text-white fs-4"></i>
                                                    }
                                                    else
                                                    {
                                                        <img src="@product.ImageURL" alt="@product.Name" class="img-fluid" style="width: 48px; height: 48px; object-fit: cover; border-radius: 8px; border: 1px solid #eee;" />
                                                    }
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-white">@product.Name</div>
                                                    <div class="small text-muted text-truncate" style="max-width: 200px;">
                                                        @product.Description
                                                    </div>
                                                </div>
                                            </div>
                                        </td>

                                        <td>
                                            <span class="badge bg-secondary text-light rounded-pill px-3">
                                                @(product.Category?.Name ?? "Uncategorized")
                                            </span>
                                        </td>

                                        <td class="text-white fw-bold">@product.Qty</td>

                                        <td class="text-white">£@product.Price.ToString("N2")</td>

                                        <td>
                                            @if (product.Qty > 10)
                                            {
                                                <span class="badge bg-success text-white rounded-pill">Available</span>
                                            }
                                            else if (product.Qty > 0)
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill">Low Stock</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger text-white rounded-pill">Out of Stock</span>
                                            }
                                        </td>

                                        <td class="text-end pe-4">
                                            <button class="btn btn-link text-warning p-0 me-3" title="Edit"
                                                    @onclick="() => EditProduct(product)">
                                                <i class="bi bi-pencil-fill"></i>
                                            </button>
                                            <button class="btn btn-link text-danger p-0" title="Delete"
                                                    @onclick="() => DeleteProduct(product)">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="p-1 border-top border-secondary">
                    <Pagination CurrentPage="currentPage"
                                TotalPages="TotalPages"
                                SelectedPage="ChangePage" />
                </div>
            </div>
        </div>
    }
</div>

<!-- Add/Edit Modal -->
@if (showFormModal)
{
    <div class="modal show d-block modal-color">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary shadow-lg">

                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">
                        <i class="bi @(isEditing ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                        @(isEditing ? "Edit Product" : "New Product")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="productModel" OnValidSubmit="SaveProduct">
                        <DataAnnotationsValidator />

                        <div class="row">
                            <div class="col-md-7">

                                <div class="mb-3">
                                    <label class="form-label small text-white text-uppercase">Name</label>
                                    <InputText class="form-control bg-secondary text-white border-0"
                                               @bind-Value="productModel.Name" placeholder="Ex: iPhone 15" />
                                    <ValidationMessage For="@(() => productModel.Name)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small text-white text-uppercase">Category</label>
                                    <InputSelect class="form-select bg-secondary text-white border-0" @bind-Value="productModel.CategoryId">
                                        <option value="0">-- Select a Category --</option>
                                        @foreach (var category in categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => productModel.CategoryId)" />
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-3">
                                        <label class="form-label small text-white text-uppercase">Price ($)</label>
                                        <InputNumber class="form-control bg-secondary text-white border-0"
                                                     @bind-Value="productModel.Price" />
                                        <ValidationMessage For="@(() => productModel.Price)" />
                                    </div>
                                    <div class="col-6 mb-3">
                                        <label class="form-label small text-white text-uppercase">Stock (Qty)</label>
                                        <InputNumber class="form-control bg-secondary text-white border-0"
                                                     @bind-Value="productModel.Qty" />
                                        <ValidationMessage For="@(() => productModel.Qty)" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small text-white text-uppercase">Description</label>
                                    <InputTextArea class="form-control bg-secondary text-white border-0"
                                                   rows="3" @bind-Value="productModel.Description" />
                                    <ValidationMessage For="@(() => productModel.Description)" />
                                </div>

                            </div>

                            <div class="col-md-5 d-flex flex-column">
                                <label class="form-label small text-white text-uppercase">Image</label>

                                <div class="mb-3">
                                    <InputFile OnChange="@HandleImageUpload"
                                               class="form-control bg-secondary text-white border-0"
                                               accept=".jpg,.jpeg,.png">
                                    </InputFile>
                                </div>

                                <InputText class="form-control d-none" @bind-Value="productModel.ImageURL"></InputText>
                                <ValidationMessage For="@(() => productModel.ImageURL)"></ValidationMessage>

                                
                                <div class="card bg-secondary border-0 d-flex align-items-center justify-content-center flex-grow-1 overflow-hidden position-relative">                                
                                    @if (isUploading)
                                    {
                                        <div class="text-center">
                                            <div class="spinner-border text-light mb-2"></div>
                                            <p class="small text-white mb-0">Uploading.....</p>
                                        </div>
                                    }
                                    else if(!string.IsNullOrWhiteSpace(productModel.ImageURL))
                                    {
                                         <img  src="@productModel.ImageURL" class="img-fluid rounded" 
                                            style="max-height:250px; object-fit:contain;"/>
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-arrow-up" style="font-size: 3rem;"></i>
                                        <p class="small">Select a file</p>
                                    }                                  

                                </div>
                            </div>
                        </div>

                        <div class="modal-footer border-secondary mt-3">
                            <button type="button" class="btn btn-outline-light" @onclick="CloseModal">Cancel</button>

                            <button type="submit" class="btn btn-primary px-4" disabled="@(isSaving || isUploading)">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                @(isUploading ? "Uploading..." : (isEditing ? "Update" : "Save"))
                            </button>
                        </div>

                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}