﻿@if (Product is not null)
{
<div class="modal-backdrop fade show" style="z-index: 1040;"></div>

    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">

                <button type="button" class="btn-close position-absolute top-0 end-0 m-3"
                        style="z-index: 10; background-color: white; padding: 10px; border-radius: 50%; box-shadow: 0 2px 5px rgba(0,0,0,0.2);"
                        @onclick="OnClose"></button>

                <div class="row g-0">

                    <div class="col-md-6 bg-light d-flex align-items-center justify-content-center p-0 position-relative">
                        <img src="@(string.IsNullOrEmpty(Product.ImageURL) ? "/images/no-image.png" : Product.ImageURL)" 
                             alt="@Product.Name" class="img-fluid"
                             style="height: 100%; width: 100%; object-fit: cover; min-height: 400px;" />

                        @if (Product.Price < 15)
                        {
                            <span class="badge bg-danger position-absolute bottom-0 start-0 m-3 px-3 py-2 rounded-pill">
                                🔥 OFFER
                            </span>
                        }
                    </div>

                    <div class="col-md-6 p-5 d-flex flex-column justify-content-center bg-white">

                        <div class="text-uppercase text-muted fw-bold small mb-2" style="letter-spacing: 1px;">
                            @(Product.Category?.Name ?? "General")
                        </div>

                        <h2 class="fw-bold text-dark mb-3">@Product.Name</h2>

                        <h3 class="fw-bold mb-4"
                            style="background: linear-gradient(135deg, #d84315 0%, #b71c1c 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                            $@Product.Price.ToString("N2")
                        </h3>

                        <p class="text-secondary mb-4" style="line-height: 1.6;">
                            @Product.Description
                            <br /><br />
                            <small class="text-muted">
                                Includes official warranty and original packaging.
                                Delivery available within 24 hours.
                            </small>
                        </p>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg fw-bold rounded-pill"
                                    style="background: linear-gradient(135deg, #d84315 0%, #b71c1c 100%); border: none;"
                                    @onclick="HandledAddToCart"
                                    disabled="@isProcessing">
                                
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span> <span>Adding...</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-cart-plus me-2"></i> Add to Cart</span>
                                }
                            </button>

                            <button class="btn btn-outline-secondary btn-sm rounded-pill mt-2" @onclick="OnClose">
                                Continue Shopping
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
}