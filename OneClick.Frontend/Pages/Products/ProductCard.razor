@using OneClick.Shared.Entities

<div class="card product-card shadow-sm h-100">

    @if (Product.Price < 15)
    {
        <div class="offer-badge">
            <span>🔥</span> OFFER
        </div>
    }
       
    <div class="product-media-container" @onclick="HandledViewDetails">
        <img src="@Product.ImageURL" class="product-media border" style="border:16px;" alt="@Product.Name" />
        <div class="hover-overlay">
            <i class="bi bi-eye-fill text-white fs-1 "></i>
        </div>
    </div>
       

    <div class="card-body d-flex flex-column">
        <h5 class="card-title fw-bold text-muted">@Product.Name</h5>
        <p class="card-text text-muted small flex-grow-1">@Product.Description</p>

        <hr class="m-0" style="border-color: grey;" />

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div class="d-flex flex-column">
                <small class="text-white" style="font-size: 0.75rem;">Price</small>
                <span class="price-tag" style="line-height: 1;">
                    £@Product.Price.ToString("N2")
                </span>
            </div>

            <div class="d-flex flex-column align-items-end">
                <small class="text-white text-muted" style="font-size: 0.75rem;">In Stock</small>

                <div class="@(Product.Qty > 0 ? "text-info" : "text-secondary") fw-bold"
                     style="font-size: 1rem;">
                    <i class="bi bi-box-seam me-1"></i>
                    <span>@Product.Qty</span>
                </div>
            </div>

            @if (Product.Qty > 10)
            {
                <span class="badge bg-success">Available</span>
            }
            else if (Product.Qty > 5)
            {
                <span class="badge bg-warning text-dark">Low</span>
            }
            else if (Product.Qty > 0)
            {
                <span class="badge bg-danger">Last Items!</span>
            }
            else
            {
                <span class="badge bg-secondary">Out of Stock</span>
            }
        </div>

       
            <button class="btn w-100 fw-bold @(Product.Qty > 0 ? "btn-primary" : "btn-secondary")"
                disabled="@(Product.Qty == 0)"
                @onclick="HandleClick"
                style="border-radius: 12px;">
            @(Product.Qty > 0 ? "Add to Cart" : "Out of Stock")
        </button>
    </div>
</div>




