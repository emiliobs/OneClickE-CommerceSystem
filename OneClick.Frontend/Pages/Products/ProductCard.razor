@using OneClick.Shared.Entities

<style>
    /* Custom CSS for the card hover effects */
    .product-card {
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        border-radius: 16px;
        overflow: hidden;
        background-color: white;
        height: 100%;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

    /* Badge Styles */
    .offer-badge {
        position: absolute;
        top: 8px;
        right: 12px;
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
        color: white;
        padding: 2px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .product-media-container {
        text-align: center;
        /* 🆕 CAMBIO 1: Margen pequeño y elegante (10px) */
        padding: 20px;
        background: white; /* Fondo blanco limpio */
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-media {
        height: 100%;
        width: 100%;
        /* 🆕 CAMBIO 2: 'cover' llena el espacio, pero el padding lo protege */
        object-fit: cover;
        transition: transform 0.3s ease;
        /* 🆕 CAMBIO 3: Redondeamos la imagen un poco para que combine con la tarjeta */
        border-radius: 12px;
    }

    .product-card:hover .product-media {
        transform: scale(1.05);
    }

    .product-card:hover .product-media {
        transform: scale(1.03); /* Efecto zoom un poco más sutil */
    }

    .price-tag {
        font-weight: bold;
        font-size: 1.5rem;
        background: linear-gradient(135deg, #d84315 0%, #b71c1c 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>

<div class="card product-card shadow-sm h-100">

    @if (Product.Price < 15)
    {
        <div class="offer-badge">
            <span>🔥</span> OFFER
        </div>
    }

    <div class="card product-card shadow-sm">
        <div class="product-media-container" style="cursor:pointer;" @onclick="HandledViewDetails">
            <img src="@Product.ImageURL" class="product-media" alt="@Product.Name" />
           @*  <div class="hover-overlay">
                <i class="bi bi-eye-fill text-white fs-1"></i>
            </div> *@
        </div>       
    </div>

    

    <div class="card-body d-flex flex-column">
        <h5 class="card-title fw-bold text-white">@Product.Name</h5>
        <p class="card-text text-white small flex-grow-1">@Product.Description</p>

        <hr class="my-o" style="border-color: rgba(255,255,255,0.5);" />

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div class="d-flex flex-column">
                <small class="text-white" style="font-size: 0.75rem;">Price</small>
                <span class="price-tag" style="line-height: 1;">
                    £@Product.Price.ToString("N2")
                </span>
            </div>

            <div class="d-flex flex-column align-items-end">
                <small class="text-white" style="font-size: 0.75rem;">In Stock</small>

                <div class="@(Product.Qty > 0 ? "text-info" : "text-secondary") fw-bold"
                     style="font-size: 1rem;">
                    <i class="bi bi-box-seam me-1"></i>
                    <span>@Product.Qty</span>
                </div>
            </div>

            @if (Product.Qty > 10)
            {
                <span class="badge bg-success">Available</span>
            }
            else if (Product.Qty > 5)
            {
                <span class="badge bg-warning text-dark">Low</span>
            }
            else if (Product.Qty > 0)
            {
                <span class="badge bg-danger">Last Items!</span>
            }
            else
            {
                <span class="badge bg-secondary">Out of Stock</span>
            }
        </div>

       
            <button class="btn w-100 fw-bold @(Product.Qty > 0 ? "btn-primary" : "btn-secondary")"
                disabled="@(Product.Qty == 0)"
                @onclick="HandleClick"
                style="border-radius: 12px;">
            @(Product.Qty > 0 ? "Add to Cart" : "Out of Stock")
        </button>
    </div>
</div>




