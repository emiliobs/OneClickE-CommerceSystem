@page "/profile"
@using Microsoft.AspNetCore.Authorization
@using OneClick.Shared.DTOs
@attribute [Authorize]

<PageTitle>My Dashboard - OneClick</PageTitle>

<style>
    .avatar-box {
        position: relative;
        width: 150px;
        height: 150px;
        margin: 0 auto;
    }

    .avatar-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 4px solid #dc3545;
        border-radius: 50%;
    }

    .avatar-placeholder {
        font-size: 5rem;
        line-height: 150px;
        color: #dc3545;
        background-color: #f8f9fa;
        border-radius: 50%;
        border: 4px solid #dc3545;
        display: block;
    }

    .avatar-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.7);
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
        cursor: pointer;
    }

    .avatar-box-editable:hover .avatar-overlay {
        opacity: 1;
    }
</style>

<div class="container mt-4 fade-in">
    <div class="row">
        
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center p-4">
                    
                    <div class="mb-3">
                        <div class="avatar-box @(isEditing ? "avatar-box-editable" : "") mb-3">
                            @if (!string.IsNullOrEmpty(_imagePreviewUrl))
                            {
                                <img src="@_imagePreviewUrl" class="avatar-image" alt="Profile Picture" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle avatar-placeholder"></i>
                            }

                            @if (isEditing)
                            {
                                <label for="profileImageInput" class="avatar-overlay">
                                    <i class="bi bi-camera-fill fs-1"></i>
                                </label>
                                <InputFile id="profileImageInput" OnChange="OnFilesSelected" class="d-none" accept="image/png,image/jpeg" />
                            }
                        </div>
                    </div>

                    @if (userProfile != null)
                    {
                        <h4 class="fw-bold mb-1">@userProfile.FirstName @userProfile.LastName</h4>
                        <p class="text-muted mb-3">@userProfile.Email</p>
                        <span class="badge bg-danger rounded-pill px-3 py-2">
                            <i class="bi bi-shield-lock-fill me-1"></i> @userProfile.Role Account
                        </span>
                    }
                    else if (isLoading)
                    {
                        <div class="spinner-border text-danger" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                    <ul class="nav nav-tabs border-bottom-0" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active text-danger fw-bold border-0 bg-transparent" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab" aria-selected="true">
                                <i class="bi bi-info-circle me-1"></i> Personal Info
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link text-muted fw-bold border-0 bg-transparent" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab" aria-selected="false">
                                <i class="bi bi-box-seam me-1"></i> My Orders
                            </button>
                        </li>
                    </ul>
                    <hr class="mt-0 mb-3" />
                </div>
                
                <div class="card-body p-4 pt-2">
                    <div class="tab-content" id="profileTabContent">
                        
                        <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="info-tab">
                            <h5 class="fw-bold mb-4">Account Details</h5>
                            
                            @if (userProfile != null)
                            {
                                @if (!isEditing)
                                {
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">First Name</div>
                                        <div class="col-sm-8 fw-bold">@userProfile.FirstName</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Last Name</div>
                                        <div class="col-sm-8 fw-bold">@userProfile.LastName</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Email Address</div>
                                        <div class="col-sm-8 fw-bold">@userProfile.Email</div>
                                    </div>
                                    
                                    <div class="mt-5">
                                        <button class="btn btn-outline-danger" @onclick="ToggleEditMode">
                                            <i class="bi bi-pencil-square me-2"></i> Edit Profile
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <EditForm Model="userProfile" OnValidSubmit="SaveProfile">
                                        <DataAnnotationsValidator />

                                        <div class="row mb-3 align-items-center">
                                            <div class="col-sm-4 text-muted fw-bold">First Name</div>
                                            <div class="col-sm-8">
                                                <InputText class="form-control shadow-none" @bind-Value="userProfile.FirstName" />
                                                <ValidationMessage For="@(() => userProfile.FirstName)" class="text-danger small" />
                                            </div>
                                        </div>
                                        
                                        <div class="row mb-3 align-items-center">
                                            <div class="col-sm-4 text-muted fw-bold">Last Name</div>
                                            <div class="col-sm-8">
                                                <InputText class="form-control shadow-none" @bind-Value="userProfile.LastName" />
                                                <ValidationMessage For="@(() => userProfile.LastName)" class="text-danger small" />
                                            </div>
                                        </div>
                                        
                                        <div class="row mb-4 align-items-center">
                                            <div class="col-sm-4 text-muted fw-bold">Email Address</div>
                                            <div class="col-sm-8">
                                                <input type="email" class="form-control bg-light text-muted shadow-none" value="@userProfile.Email" disabled />
                                                <small class="text-muted"><i class="bi bi-lock-fill"></i> Emails cannot be changed.</small>
                                            </div>
                                        </div>

                                        <div class="mt-5 d-flex gap-2">
                                            <button type="submit" class="btn btn-danger px-4" disabled="@isSaving">
                                                @if (isSaving)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                                }
                                                <i class="bi bi-save me-1"></i> Save
                                            </button>
                                            <button type="button" class="btn btn-outline-secondary px-4" @onclick="ToggleEditMode" disabled="@isSaving">
                                                Cancel
                                            </button>
                                        </div>
                                    </EditForm>
                                }
                            }
                        </div>

                        <div class="tab-pane fade" id="orders" role="tabpanel" aria-labelledby="orders-tab">
                            <div class="text-center py-5">
                                <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
                                <h5 class="mt-3 text-muted">No orders yet</h5>
                                <p class="text-secondary small">When you make a purchase, it will appear here.</p>
                                <a href="/" class="btn btn-danger mt-3">Start Shopping</a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>