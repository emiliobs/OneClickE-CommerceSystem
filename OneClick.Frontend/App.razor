@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            
            @* The DefaultLayout here already applies the menu! *@
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                
                <NotAuthorized>
                    @* REMOVED the LayoutView from here to prevent the double-menu bug! *@
                    <div class="container text-center mt-5 fade-in">
                        <div class="row justify-content-center">
                            <div class="col-md-6">
                                <i class="bi bi-shield-lock text-danger" style="font-size: 6rem;"></i>
                                <h1 class="fw-bold mt-3 text-white">Access Denied</h1>
                                <p class="text-secondary fs-5 mt-2">
                                    Oops! You don't have the required administrative permissions to view this page.
                                </p>
                                <a href="/" class="btn btn-danger btn-lg mt-4 px-4 rounded-pill shadow">
                                    <i class="bi bi-house-door-fill me-2"></i> Return to Safety
                                </a>
                            </div>
                        </div>
                    </div>
                </NotAuthorized>

            </AuthorizeRouteView>
            
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        
        <NotFound>
            <PageTitle>Not found</PageTitle>
            @* The 404 page DOES need the LayoutView because it is outside the RouteView *@
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="container text-center mt-5 fade-in">
                    <i class="bi bi-emoji-frown text-warning" style="font-size: 6rem;"></i>
                    <h1 class="fw-bold mt-3 text-white">404 - Page Not Found</h1>
                    <p class="text-secondary fs-5 mt-2">Sorry, there's nothing at this address.</p>
                    <a href="/" class="btn btn-outline-warning mt-3 rounded-pill">Take me home</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>